.gitlab-ci-local/

# Signing keys — NEVER commit private keys
keys/
# Public verification keys are served from .well-known (RFC 8615)
!public/.well-known/cosign.pub
!public/.well-known/cosign.pub.license

# Node / Playwright
node_modules/
test-results/
playwright-report/
